# SafeTabi 環境変数のサンプル
# このファイルをコピーして .env を作成し、各値を Supabase ダッシュボードから設定する。
#   cp .env.example .env
# .env は .gitignore 済み。実際のキーをコミットしないこと。

# Supabase プロジェクトの URL (Project Settings > API)
SUPABASE_URL=https://<your-project-ref>.supabase.co

# 公開用の anon キー (クライアント/アプリ用。RLS により読み取りのみ可能)
SUPABASE_ANON_KEY=

# service_role キー (データ収集スクリプト専用。RLS をバイパスする秘密鍵。絶対に公開しない)
SUPABASE_SERVICE_ROLE_KEY=

# DB 直結用の接続文字列 (Project Settings > Database。マイグレーション適用・収集スクリプト用)
SUPABASE_DB_URL=postgresql://postgres:<password>@db.<your-project-ref>.supabase.co:5432/postgres

# PoC 対象自治体の気象庁エリアコード (東京都 = 130000。doc/decisions.md 参照)
POC_AREA_CODE=130000
